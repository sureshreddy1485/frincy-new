generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  phone            String?          @unique
  passwordHash     String?
  recoveryCodeHash String?
  name             String?
  avatarUrl        String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
  version          Int              @default(1)
  auditLogs        AuditLog[]
  memberships      BusinessMember[]
  sessions         DeviceSession[]
  folderMembers    FolderMember[]
  notifications    Notification[]
  refreshTokens    RefreshToken[]
  userSettings     UserSettings?
}

model UserSettings {
  id        String    @id @default(uuid())
  userId    String    @unique
  darkMode  Boolean   @default(false)
  language  String    @default("en")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  version   Int       @default(1)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Business {
  id           String            @id @default(uuid())
  name         String
  currency     String            @default("INR")
  logoUrl      String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?
  version      Int               @default(1)
  activityLogs ActivityLog[]
  members      BusinessMember[]
  settings     BusinessSettings?
  categories   Category[]
  customers    Customer[]
  customerGrps CustomerGroup[]
  editHistory  EditHistory[]
  invitations  Invitation[]
  ledgers      Ledger[]
  reminders    Reminder[]
  tags         Tag[]
}

model BusinessSettings {
  id         String    @id @default(uuid())
  businessId String    @unique
  timezone   String    @default("Asia/Kolkata")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  version    Int       @default(1)
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model BusinessMember {
  id         String    @id @default(uuid())
  userId     String
  businessId String
  role       Role      @default(VIEWER)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  version    Int       @default(1)
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([businessId])
}

model CustomerGroup {
  id            String         @id @default(uuid())
  businessId    String
  name          String
  description   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  version       Int            @default(1)
  customers     Customer[]
  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  folderInvites FolderInvite[]
  folderMembers FolderMember[]

  @@index([businessId])
}

model Customer {
  id         String         @id @default(uuid())
  businessId String
  groupId    String?
  name       String
  phone      String?
  email      String?
  address    String?
  balance    Float          @default(0.0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?
  version    Int            @default(1)
  business   Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  group      CustomerGroup? @relation(fields: [groupId], references: [id])
  ledgers    Ledger[]

  @@index([businessId])
  @@index([groupId])
}

model Ledger {
  id           String        @id @default(uuid())
  businessId   String
  customerId   String?
  name         String
  type         String        @default("GENERAL")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  version      Int           @default(1)
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([businessId])
  @@index([customerId])
}

model Category {
  id           String        @id @default(uuid())
  businessId   String
  name         String
  type         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  version      Int           @default(1)
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([businessId])
}

model Tag {
  id           String           @id @default(uuid())
  businessId   String
  name         String
  color        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?
  version      Int              @default(1)
  business     Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions TransactionTag[]

  @@index([businessId])
}

model Transaction {
  id          String           @id @default(uuid())
  ledgerId    String
  categoryId  String?
  amount      Float
  type        TransactionType
  date        DateTime
  note        String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  version     Int              @default(1)
  attachments Attachment[]
  category    Category?        @relation(fields: [categoryId], references: [id])
  ledger      Ledger           @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  tags        TransactionTag[]

  @@index([ledgerId])
  @@index([categoryId])
  @@index([date])
}

model TransactionTag {
  transactionId String
  tagId         String
  id            String      @id @default(uuid())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  version       Int         @default(1)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@unique([transactionId, tagId])
  @@index([transactionId])
  @@index([tagId])
}

model Attachment {
  id            String      @id @default(uuid())
  transactionId String
  fileUrl       String
  fileType      String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  version       Int         @default(1)
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

model ActivityLog {
  id         String    @id @default(uuid())
  businessId String
  userId     String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  version    Int       @default(1)
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([userId])
}

model Reminder {
  id         String         @id @default(uuid())
  businessId String
  title      String
  dueDate    DateTime
  status     ReminderStatus @default(PENDING)
  relatedId  String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?
  version    Int            @default(1)
  business   Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  title     String
  body      String
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  version   Int       @default(1)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FolderMember {
  id          String            @id @default(uuid())
  userId      String
  groupId     String
  role        Role              @default(VIEWER)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?
  version     Int               @default(1)
  group       CustomerGroup     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions FolderPermission?

  @@unique([userId, groupId])
  @@index([groupId])
}

model FolderPermission {
  id                   String       @id @default(uuid())
  memberId             String       @unique
  canView              Boolean      @default(true)
  canCreateCustomer    Boolean      @default(false)
  canEditCustomer      Boolean      @default(false)
  canDeleteCustomer    Boolean      @default(false)
  canCreateTransaction Boolean      @default(false)
  canEditTransaction   Boolean      @default(false)
  canDeleteTransaction Boolean      @default(false)
  canExport            Boolean      @default(false)
  canManageMembers     Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  deletedAt            DateTime?
  version              Int          @default(1)
  member               FolderMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model FolderInvite {
  id         String        @id @default(uuid())
  groupId    String
  token      String        @unique
  status     String        @default("ACTIVE")
  usageCount Int           @default(0)
  maxUses    Int           @default(1)
  expiresAt  DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  deletedAt  DateTime?
  version    Int           @default(1)
  group      CustomerGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([token])
}

model EditHistory {
  id            String    @id @default(uuid())
  businessId    String
  userId        String
  userRole      String
  recordType    String
  recordId      String
  previousValue Json
  newValue      Json
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  version       Int       @default(1)
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([recordId])
}

model Invitation {
  id         String    @id @default(uuid())
  businessId String
  email      String?
  phone      String?
  role       Role      @default(STAFF)
  status     String    @default("PENDING")
  token      String    @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  version    Int       @default(1)
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([email])
  @@index([phone])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DeviceSession {
  id           String   @id @default(uuid())
  userId       String
  deviceId     String?  @unique
  deviceName   String?
  platform     String?
  ipAddress    String?
  userAgent    String?
  lastActiveAt DateTime @default(now())
  pushToken    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SyncMetadata {
  id           String    @id @default(uuid())
  userId       String    @unique
  lastPulledAt DateTime?
  lastPushedAt DateTime?
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   String?
  ipAddress String?
  level     String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum TransactionType {
  GAVE
  GOT
  INCOME
  EXPENSE
}

enum ReminderStatus {
  PENDING
  COMPLETED
  CANCELLED
}
